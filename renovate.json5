{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests", // to pin digests of docker images
    ":dependencyDashboard"
  ],

  // Don't limit PRs: useful to get all updates asap + to avoid issues
  // if the bot state doesn't match github state (branch deleted by hand etc.)
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,

  // Automerge
  "automerge": true,
  "automergeType": "branch",

  // Only automerge digest and patch updates (not major/minor,
  // e.g. we don't want to bump python 3.14 to 3.15 automatically)
  "packageRules": [
    {
      "matchUpdateTypes": ["major", "minor"],
      "automerge": false
    }
  ],

  // For Dockerfile
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["**/Dockerfile"],
      "matchStrings": [
        "#\\s*renovate:\\s+depName=(?<depName>\\S+)\\nARG \\w+=(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "deb",
      "registryUrlTemplate": "https://deb.debian.org/debian?suite=trixie&components=main&binaryArch=amd64",
      "versioningTemplate": "deb"
    }
  ]
}
